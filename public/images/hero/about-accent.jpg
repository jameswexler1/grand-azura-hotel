<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1a1020"/>
      <stop offset="100%" stop-color="#0e1626"/>
    </linearGradient>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(184,144,74,0.06)" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="1200" height="800" fill="url(#bg)"/>
  <rect width="1200" height="800" fill="url(#grid)"/>
  <!-- Decorative frame -->
  <rect x="40" y="40" width="1120" height="720" fill="none" stroke="rgba(184,144,74,0.15)" stroke-width="1"/>
  <!-- Centre ornament -->
  <g transform="translate(600,400)" opacity="0.6">
    <line x1="-60" y1="0" x2="-20" y2="0" stroke="#b8904a" stroke-width="1"/>
    <line x1="20" y1="0" x2="60" y2="0" stroke="#b8904a" stroke-width="1"/>
    <circle cx="0" cy="0" r="4" fill="#b8904a"/>
  </g>
  <!-- Label text -->
  <text x="600" y="370" font-family="Georgia, serif" font-size="18" fill="rgba(184,144,74,0.5)"
        text-anchor="middle" letter-spacing="4">GRAND AZURA HOTEL</text>
  <text x="600" y="415" font-family="Georgia, serif" font-size="28" fill="rgba(240,232,208,0.35)"
        text-anchor="middle" font-style="italic">Interior Detail · Genoese Ceramics</text>
  <text x="600" y="445" font-family="monospace" font-size="11" fill="rgba(184,144,74,0.3)"
        text-anchor="middle">images/hero/about-accent.jpg</text>
  <!-- Corner marks -->
  <g stroke="rgba(184,144,74,0.2)" stroke-width="1" fill="none">
    <path d="M60 60 L100 60 M60 60 L60 100"/>
    <path d="M1140 60 L1100 60 M1140 60 L1140 100"/>
    <path d="M60 740 L100 740 M60 740 L60 700"/>
    <path d="M1140 740 L1100 740 M1140 740 L1140 700"/>
  </g>
</svg>
